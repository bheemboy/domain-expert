project:
  key: {{JIRA_KEY}}
  name: {{PRODUCT_NAME}}
  config_dir: {{CONFIG_DIR}}

jira:
  base_url: {{JIRA_BASE_URL}}
  jql: |
    {{JIRA_JQL}}

sources: {{SOURCE_REPOS_YAML_LIST}}

# Optional. Where this product's customer-facing online help (online docs) lives —
# a SEPARATE repo or folder, never the wiki. Used by /wiki-doc-review and
# /wiki-doc-author to locate "the documentation". A relative path resolves against
# this wiki repo's root; absolute or ~ paths are used as-is. `location` may be a
# single path or a list. `include`/`exclude` are gitignore-style globs over each
# location-relative path (default include: Markdown/MDX; default exclude: none).
# The plugin only ever READS these files during review.
# If a docs location resolves INSIDE a `sources` repo, the ingest pipeline
# auto-excludes it (scan, backfill, and dry-run all skip it) so the docs are
# never pulled into the wiki — preventing a wiki→docs→wiki loop. To deliberately
# seed an existing system's online help once, point the path form at it:
# `/wiki-ingest <docs-path>` (it bypasses ignore rules).
# docs:
#   location: ../cid-docs
#   include:
#     - "docs/**/*.md"
#     - "docs/**/*.mdx"
#   exclude:
#     - "**/node_modules/**"

lint:
  flaggable_nouns: []
  brand_nouns: {{BRAND_TERMS_YAML_LIST}}
  era_terms: []    # optional list of retired era/version terms (e.g. ["v1", "legacy"])

# Optional. Enables /wiki-defect-review as a first-line reviewer on this
# project's new defects (see README "Defect review" for the rollout ladder).
# Interactive spot reviews (`/wiki-defect-review <KEY>`) work without this
# block; `--auto` polling requires it and is OFF until `enabled: true`.
# `mode` is the trust switch: `draft` emails you each proposed comment via
# Jira's notify API (nothing appears on the ticket; you paste the good ones);
# `post` comments directly. Use your project's real issue-type/status names
# in candidate_jql (Defect vs Bug varies per project). The project key, the
# 10-minute cool-down, and the bot marker are supplied by code — never put
# them in the JQL. `qmd_collection_prefix` is only for servers with a unified
# qmd index (the app-registry key, e.g. `cid` — NOT the Jira project key).
# defect_review:
#   enabled: true
#   mode: draft                  # draft | post
#   notify_user: you@example.com
#   candidate_jql: 'issuetype = Defect AND status in ("New", "Open")'
#   max_question_rounds: 3
#   qmd_collection_prefix: ""    # server/unified-index only; leave "" on dev

# Optional. Tunes how the synth phase batches and routes work. Everything here is
# commented out: the pipeline ships with these exact defaults baked in, so you only
# need a key if you want to override it after watching real ingests. Lines are raw
# line counts; cutoffs differ per kind because the unit isn't equivalent across them.
# synth_tuning:
#   default_batch: 12       # items per batch when an item has no triage metadata
#   jira:
#     small_lines: 150      # below this: batch up to small_batch
#     solo_lines: 400       # at/above this: one item per agent
#     small_batch: 15
#     mid_batch: 6          # batch size between small_lines and solo_lines
#   doc:
#     small_lines: 250
#     solo_lines: 700
#     small_batch: 15
#     mid_batch: 4
#   code:                   # also covers prose
#     small_lines: 400
#     solo_lines: 1500
#     small_batch: 15
#     mid_batch: 3

# Optional. Extra paths to exclude from ingest, matched (gitignore-style) over each
# file's repo-relative path BEFORE it enters the queue — so junk never reaches extract
# or synth. The pipeline already ignores a built-in set for free: node_modules/ and
# vendor/ trees, minified/map/bundle output, *.d.ts and *.metadata.json, lockfiles,
# binary assets (images/fonts/media), styling (*.css/*.scss/…), and *.pem. List here
# only repo-specific trees the defaults miss — most commonly a compiled library that is
# committed into the source tree. Semantics: `**/` = any depth, `*` = within one path
# segment, `?` = one char; a pattern without a leading `**/` is anchored at the repo root.
# Escape hatch: a genuinely valuable ignored asset (e.g. an architecture PNG) can be
# force-enqueued past these globs — `/wiki-queue <path|folder>` (queue only) or
# `/wiki-ingest <path|folder>` (queue, then ingest). Both bypass the filter for every
# file except extract-owned imports, which are never enqueued as sources.
# ignore:
#   - ac_portal/local_modules/**     # committed compiled Angular lib (vendored)
#   - ac_ops/terraform/**            # infra-as-code, not product-domain behavior
#   - "**/database_migrations/versions/**"   # autogenerated, redundant with model/
#   - "**/test_*/**"                 # test scaffolding
