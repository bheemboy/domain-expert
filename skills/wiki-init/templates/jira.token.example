# Jira Cloud credentials — copy to <config_dir>/jira.token and chmod 600.
# <config_dir> is project.config_dir from wiki.config.yaml: machine-local,
# OUTSIDE the wiki repo, never committed.
#
# Generate the API token at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
#
# Read by the plugin's Jira scripts (jira_utils.py). The JIRA_EMAIL /
# JIRA_TOKEN environment variables override this file when set.

JIRA_EMAIL=you@example.com
JIRA_TOKEN=<api-token>
